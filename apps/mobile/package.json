{
  "name": "@snacky/mobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "ios:simulator": "react-native run-ios --simulator 'iPhone 17 Pro'",
    "ios:simulator:staging": "ENVFILE=.env.staging react-native run-ios --simulator 'iPhone 17 Pro'",
    "ios:device": "ENVFILE=.env.staging react-native run-ios --device",
    "ios:staging": "ENVFILE=.env.staging react-native run-ios --mode Release --device --no-packager",
    "build:ios:staging": "ENVFILE=.env.staging xcodebuild -workspace ios/Snacky.xcworkspace -scheme Snacky -configuration Release -sdk iphoneos -derivedDataPath ios/build -allowProvisioningUpdates build",
    "start": "react-native start",
    "start:wireless": "ENVFILE=.env.wireless react-native start --host 0.0.0.0",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:ci": "jest --ci --coverage --passWithNoTests",
    "clean": "react-native clean"
  },
  "codegenConfig": {
    "name": "SnackySpecs",
    "type": "all",
    "jsSrcsDir": "src/native"
  },
  "dependencies": {
    "@bam.tech/react-native-image-resizer": "^3.0.11",
    "@gluestack-style/react": "^1.0.57",
    "@gluestack-ui/config": "^1.1.20",
    "@gluestack-ui/themed": "^1.1.73",
    "@hookform/resolvers": "^5.x",
    "@react-native-community/slider": "^5.1.2",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/messaging": "^23.8.8",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.x",
    "@react-navigation/native": "^7.x",
    "@react-navigation/native-stack": "^7.x",
    "@snacky/api-client": "workspace:*",
    "@snacky/shared-types": "workspace:*",
    "@supabase/supabase-js": "^2.49.0",
    "@tanstack/react-query": "^5.x",
    "i18next": "^26.0.0",
    "intl-pluralrules": "^2.0.1",
    "invariant": "^2.2.4",
    "lucide-react-native": "^1.7.0",
    "nativewind": "^4.x",
    "react": "19.2.3",
    "react-hook-form": "^7.x",
    "react-i18next": "^17.0.0",
    "react-native": "0.84.1",
    "react-native-config": "^1.x",
    "react-native-fs": "^2.20.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-keychain": "^10.x",
    "react-native-localize": "^3.7.0",
    "react-native-marked": "^8.0.1",
    "react-native-mmkv": "^3.x",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.x",
    "react-native-svg": "^15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vision-camera": "^4.7.3",
    "react-native-worklets": "^0.8.0",
    "zod": "^3.24.0",
    "zustand": "^5.x"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@snacky/eslint-config": "workspace:*",
    "@types/invariant": "^2.2.37",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "jest": "^30.3.0",
    "react-test-renderer": "19.2.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22"
  }
}
