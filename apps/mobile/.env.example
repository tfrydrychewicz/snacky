# Local development (default) — connects to local Supabase (supabase start)
# Copy to .env
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key

# Staging — connects to cloud Supabase project
# Copy to .env.staging (gitignored)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-cloud-anon-key

GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
