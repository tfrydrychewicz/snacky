{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "lib": ["ESNext", "DOM"],
    "baseUrl": ".",
    "paths": {
      "https://esm.sh/@supabase/supabase-js@*": ["../../node_modules/@supabase/supabase-js"]
    }
  },
  "include": ["deno.d.ts", "./**/*.ts"],
  "exclude": ["node_modules"]
}
